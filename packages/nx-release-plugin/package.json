{
  "name": "@pplancq/nx-release-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "description": "pplancq nx release plugin",
  "author": "pplancq <paul.plancq@outlook.fr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pplancq/dev-tools.git",
    "directory": "packages/nx-release-plugin"
  },
  "bugs": {
    "url": "https://github.com/pplancq/dev-tools/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./generators.json": "./generators.json",
    "./migrations.json": "./migrations.json",
    "./presets/*": "./presets/*.json",
    "./changelog-renderer.cjs": "./dist/changelog-renderer.cjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "presets",
    "generators.json",
    "migrations.json",
    "README.md",
    "LICENSE"
  ],
  "generators": "./generators.json",
  "migrations": "./migrations.json",
  "nx-migrations": {
    "migrations": "./migrations.json"
  },
  "scripts": {
    "start": "rslib build --watch",
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:eslint": "eslint \"**/*.{js,mjs,ts}\"",
    "lint:eslint:fix": "eslint \"**/*.{js,mjs,ts}\" --fix",
    "lint:prettier": "prettier \"**/*.!(js|mjs|ts)\" --check --ignore-unknown",
    "lint:prettier:fix": "prettier \"**/*.!(js|mjs|ts)\" --write --ignore-unknown",
    "lint:tsc": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nx",
    "release",
    "plugin",
    "config"
  ],
  "dependencies": {
    "@nx/devkit": "^23.1.0",
    "@nx/js": "^23.1.0"
  },
  "peerDependencies": {
    "nx": "^23.0.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.2",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-plugin-prettier": "^5.5.6",
    "lint-staged": "^17.0.8",
    "nx": "^23.1.0",
    "prettier": "^3.9.5",
    "tsc-files": "^1.1.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "prettier": "@pplancq/prettier-config",
  "lint-staged": {
    "*.(js|mjs|ts)": "eslint --fix",
    "*.ts": "tsc-files --noEmit",
    "*.!(js|mjs|ts)": "prettier --write --ignore-unknown"
  }
}
